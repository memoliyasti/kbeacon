              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "links": [
            {
              "title": "Open Secret impact in KBeacon API",
              "url": "${kbeacon_api_url}/api/v1/secrets/${__field.labels.namespace}/${__field.labels.secret_name}/impact",
              "targetBlank": true
            },
            {
              "title": "Open dependency map filtered by Secret",
              "url": "${kbeacon_api_url}/api/v1/dependency-map?secretNamespace=${__field.labels.namespace}&secretName=${__field.labels.secret_name}&limit=100",
              "targetBlank": true
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
