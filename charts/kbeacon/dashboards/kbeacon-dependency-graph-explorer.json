          "editorMode": "code",
          "expr": "topk(25, kbeacon_secret_impact_score{job=~\"$job\",cluster=~\"$cluster\",namespace=~\"$namespace\",owner_team=~\"$owner_team\",criticality=~\"$criticality\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
