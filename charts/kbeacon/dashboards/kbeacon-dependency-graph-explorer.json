  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_build_info, job)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_cluster_dependency_count{job=~\"$job\"}, cluster)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Workload namespace",
        "datasource": {
          "type": "prometheus",
