  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Dependency edges by team",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, owner_team) (kbeacon_dependency_edges{job=~\"$job\",cluster=~\"$cluster\",owner_team=~\"$owner_team\"})",
          "legendFormat": "{{cluster}} / {{owner_team}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open dependency map filtered by owner team",
              "url": "${kbeacon_api_url}/api/v1/dependency-map?ownerTeam=${__field.labels.owner_team}&limit=100",
              "targetBlank": true
            },
            {
              "title": "Open Secrets filtered by owner team",
              "url": "${kbeacon_api_url}/api/v1/secrets?ownerTeam=${__field.labels.owner_team}&limit=100",
              "targetBlank": true
            },
            {
              "title": "Open Workloads filtered by owner team",
              "url": "${kbeacon_api_url}/api/v1/workloads?ownerTeam=${__field.labels.owner_team}&limit=100",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
