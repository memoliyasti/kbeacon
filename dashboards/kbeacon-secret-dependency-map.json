        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, kbeacon_secret_affected_workload_count{job=~\"$job\",cluster=~\"$cluster\",namespace=~\"$namespace\",owner_team=~\"$owner_team\"})",
          "legendFormat": "{{namespace}}/{{secret_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
