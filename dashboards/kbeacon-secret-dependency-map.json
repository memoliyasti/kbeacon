        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kbeacon_dependency_edges{job=~\"$job\",cluster=~\"$cluster\",workload_namespace=~\"$namespace\",owner_team=~\"$owner_team\"}",
