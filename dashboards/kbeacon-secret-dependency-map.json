      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, namespace, secret_name) (increase(kbeacon_secret_changes_total{job=~\"$job\",cluster=~\"$cluster\",namespace=~\"$namespace\"}[$window]))",
          "legendFormat": "{{namespace}}/{{secret_name}}",
