  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top affected Secrets",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, kbeacon_secret_affected_workload_count{job=~\"$job\",cluster=~\"$cluster\",namespace=~\"$namespace\",owner_team=~\"$owner_team\"})",
          "legendFormat": "{{namespace}}/{{secret_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open Secret impact in KBeacon API",
              "url": "${kbeacon_api_url}/api/v1/secrets/${__field.labels.namespace}/${__field.labels.secret_name}/impact",
              "targetBlank": true
            },
            {
              "title": "Open dependency map filtered by Secret",
              "url": "${kbeacon_api_url}/api/v1/dependency-map?secretNamespace=${__field.labels.namespace}&secretName=${__field.labels.secret_name}&limit=100",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
