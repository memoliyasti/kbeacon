    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Workload-to-Secret dependency graph built from kbeacon_dependency_edges. Keep metrics.edge.enabled=true for this panel.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "id": 8,
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "label_join(label_join(label_join(label_join(label_join(label_join(kbeacon_dependency_edges{job=~\"$job\",cluster=~\"$cluster\",workload_namespace=~\"$namespace\",owner_team=~\"$owner_team\"}, \"source\", \"/\", \"workload_kind\", \"workload_namespace\", \"workload_name\"), \"target\", \"/\", \"secret_namespace\", \"secret_name\"), \"id\", \" -> \", \"source\", \"target\"), \"mainstat\", \" / \", \"discovery_mode\", \"resolved\"), \"detail__owner_team\", \"\", \"owner_team\"), \"detail__criticality\", \"\", \"criticality\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Dependency graph",
      "type": "nodeGraph"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "kbeacon",
    "kubernetes",
    "secrets"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_build_info, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "KBeacon job"
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_cluster_dependency_count{job=~\"$job\"}, cluster)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Cluster"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_secret_affected_workload_count{job=~\"$job\",cluster=~\"$cluster\"}, namespace)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Namespace"
      },
      {
        "name": "owner_team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_secret_impact_score{job=~\"$job\",cluster=~\"$cluster\"}, owner_team)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Owner team"
      },
      {
        "name": "window",
        "type": "custom",
        "query": "5m,15m,1h,6h,24h,7d",
        "current": {
          "text": "1h",
          "value": "1h"
        },
        "label": "Window"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "title": "KBeacon / Secret Dependency Map",
  "uid": "kbeacon-secret-dependency-map",
  "version": 2,
  "weekStart": ""
}
