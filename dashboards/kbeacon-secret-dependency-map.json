  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_build_info, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "KBeacon job"
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_cluster_dependency_count{job=~\"$job\"}, cluster)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Cluster"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_secret_affected_workload_count{job=~\"$job\",cluster=~\"$cluster\"}, namespace)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Namespace"
      },
      {
        "name": "owner_team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kbeacon_secret_impact_score{job=~\"$job\",cluster=~\"$cluster\"}, owner_team)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "label": "Owner team"
      },
      {
        "name": "window",
        "type": "custom",
        "query": "5m,15m,1h,6h,24h,7d",
        "current": {
          "text": "1h",
          "value": "1h"
        },
        "label": "Window"
      },
      {
        "name": "kbeacon_api_url",
        "label": "KBeacon API URL",
        "type": "textbox",
        "hide": 0,
        "query": "http://127.0.0.1:8081",
        "current": {
          "selected": false,
          "text": "http://127.0.0.1:8081",
          "value": "http://127.0.0.1:8081"
