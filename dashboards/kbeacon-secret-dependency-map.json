        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kbeacon_unresolved_secret_references{job=~\"$job\",cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}/{{secret_name}}",
